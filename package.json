{
  "name": "andi-cli",
  "version": "0.1.0",
  "description": "Headless CLI + CI wrapper for the SSA ANDI (Accessible Name & Description Inspector) Section 508 accessibility tool.",
  "keywords": [
    "accessibility",
    "section-508",
    "andi",
    "wcag",
    "a11y",
    "playwright",
    "ci"
  ],
  "license": "Apache-2.0",
  "author": "Arun Sanna",
  "type": "commonjs",
  "bin": {
    "andi-scan": "src/cli.cjs"
  },
  "main": "src/scanner.cjs",
  "scripts": {
    "scan": "node src/cli.cjs",
    "test": "node --test 'test/*.cjs'",
    "test:fixture": "node src/cli.cjs --url file://$PWD/examples/fixture.html"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "playwright": "1.55.0"
  },
  "optionalDependencies": {
    "@axe-core/playwright": "^4.10.0"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "fast-xml-parser": "^5.9.3",
    "node-html-parser": "^8.0.2"
  }
}
