{
  "name": "andi-cli",
  "version": "0.1.0",
  "description": "Headless CLI + CI wrapper for the SSA ANDI (Accessible Name & Description Inspector) Section 508 accessibility tool.",
  "keywords": [
    "accessibility",
    "section-508",
    "andi",
    "wcag",
    "a11y",
    "playwright",
    "ci"
  ],
  "license": "Apache-2.0",
  "author": "Arun Sanna",
  "type": "commonjs",
  "files": [
    "NOTICE",
    "andi/",
    "src/",
    "docs/ARCHITECTURE.md",
    "docs/ci/",
    "docs/output-schema.md",
    "docs/sync-upstream.md"
  ],
  "bin": {
    "andi-scan": "src/cli.cjs",
    "andi-parity": "src/parity-cli.cjs",
    "andi-benchmark": "src/benchmark-cli.cjs"
  },
  "main": "src/scanner.cjs",
  "scripts": {
    "scan": "node src/cli.cjs",
    "parity": "node src/parity-cli.cjs",
    "benchmark:browser-cli": "node src/benchmark-cli.cjs",
    "test": "node --test --test-concurrency=2 test/*.cjs",
    "test:fixture": "node src/cli.cjs --url file://$PWD/examples/fixture.html"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "playwright": "1.55.1"
  },
  "optionalDependencies": {
    "@axe-core/playwright": "^4.10.0"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "fast-xml-parser": "^5.9.3",
    "js-yaml": "^4.2.0",
    "node-html-parser": "^8.0.2"
  }
}
